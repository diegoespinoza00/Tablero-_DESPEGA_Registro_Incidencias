  <!-- TABLA DE CENTROS -->
  <div class="section-label" style="margin-top:28px">Registro por centro educativo</div>
  <div class="card" style="padding:0;">
    <div class="table-wrap">
      <table id="tabla-ces">
        <thead>
          <tr>
            <th>Código CE</th>
            <th>Centro educativo</th>
            <th>Monitor</th>
            <th class="center">Esperados</th>
            <th class="center">Presentes</th>
            <th class="center">% Asist.</th>
            <th class="center">Incidencias</th>
            <th>Inicio</th>
            <th>Receso</th>
            <th>Fin</th>
            <th class="center">Estado</th>
          </tr>
        </thead>
        <tbody id="tabla-body"></tbody>
      </table>
    </div>
  </div>

  <!-- FOOTER -->
  <div class="footer">
    <span><i class="ti ti-cloud" style="vertical-align:-2px;margin-right:4px" aria-hidden="true"></i>Datos leídos en vivo desde Google Sheets · actualización automática cada minuto.</span>
    <span>Prueba DESPEGA · Tablero operativo</span>
  </div>
</div>

<script>
/* ============================================================
   CONFIGURACIÓN
   ============================================================ */
const SHEET_ID    = '1owxrSnT6TIyw8nnN6jA_aF8YGJF-kok9HXYlwpjcUOM';
const SHEET_NAME  = 'REGISTRO INCIDENCIAS';
const REFRESH_MS  = 60000; // 60 segundos
const HANDLER     = 'onDespegaData';

/* Índices de columnas en la hoja REGISTRO INCIDENCIAS:
   0 Código CE | 1 Nombre CE | 2 Monitor | 3 Alumnos Esperados |
   4 Asistencia Total | 5 Ausencias | 6 % Asistencia | 7 Electricidad |
   8 Internet | 9 Ausencia Cuidador | 10 Ausencia Coordinador |
   11 Desorden Exterior Aula | 12 Total Incidencias |
   13 Hora Inicio Prueba | 14 Inicio Receso | 15 Hora Finalización */

let registros = [];
let chartInc = null, chartAsist = null;

/* ============================================================
   CARGA DE DATOS (JSONP — evita problemas de CORS)
   ============================================================ */
function gvizUrl() {
  return 'https://docs.google.com/spreadsheets/d/' + SHEET_ID +
         '/gviz/tq?sheet=' + encodeURIComponent(SHEET_NAME) +
         '&tqx=out:json;responseHandler:' + HANDLER +
         '&_=' + Date.now();
}

function fetchData() {
  const btn = document.getElementById('btn-refresh');
  btn.classList.add('loading');
  btn.disabled = true;
  document.getElementById('updated-info').classList.remove('err');
  document.getElementById('updated-info').textContent = 'Actualizando…';

  const old = document.getElementById('gviz-script');
  if (old) old.remove();

  const s = document.createElement('script');
  s.id = 'gviz-script';
  s.src = gvizUrl();
  s.onerror = function () { mostrarError('No se pudo conectar con el Google Sheet. Revisa la conexión.'); };
  document.body.appendChild(s);
}

function cellV(c, i) { return (c[i] && c[i].v !== null && c[i].v !== undefined) ? c[i].v : null; }
function cellF(c, i) { return c[i] ? (c[i].f !== null && c[i].f !== undefined ? c[i].f : c[i].v) : null; }

function parseRow(c) {
  if (!c) return null;
  const codigoRaw = cellV(c, 0);
  if (codigoRaw === null || codigoRaw === '') return null;
  const esperados = Number(cellV(c, 3)) || 0;
  const presentes = Number(cellV(c, 4)) || 0;
  return {
    codigo:   String(codigoRaw),
    nombre:   cellV(c, 1) || '',
    monitor:  cellV(c, 2) || '',
    esperados: esperados,
    presentes: presentes,
    elect:    Number(cellV(c, 7))  ? 1 : 0,
    internet: Number(cellV(c, 8))  ? 1 : 0,
    cuidador: Number(cellV(c, 9))  ? 1 : 0,
    coord:    Number(cellV(c, 10)) ? 1 : 0,
    desorden: Number(cellV(c, 11)) ? 1 : 0,
    inicio:   cellF(c, 13) || '—',
    receso:   cellF(c, 14) || '—',
    fin:      cellF(c, 15) || '—'
  };
}

/* Callback JSONP */
window[HANDLER] = function (resp) {
  try {
    if (!resp || resp.status === 'error' || !resp.table) {
      mostrarError('El Google Sheet devolvió una respuesta inválida.');
      return;
    }
    const rows = resp.table.rows || [];
    registros = rows.map(function (r) { return parseRow(r.c); })
                    .filter(function (x) { return x && x.codigo; });
    render();
    marcarActualizado();
  } catch (e) {
    mostrarError('Error procesando datos: ' + e.message);
  } finally {
    const btn = document.getElementById('btn-refresh');
    btn.classList.remove('loading');
    btn.disabled = false;
  }
};

function marcarActualizado() {
  document.getElementById('error-banner').style.display = 'none';
  const info = document.getElementById('updated-info');
  info.classList.remove('err');
  const ahora = new Date();
  const hora = ahora.toLocaleTimeString('es-SV', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  info.innerHTML = '<i class="ti ti-circle-check" style="vertical-align:-2px"></i> Última actualización: ' + hora;
}

function mostrarError(msg) {
  const banner = document.getElementById('error-banner');
  document.getElementById('error-text').textContent = msg;
  banner.style.display = 'flex';
  const info = document.getElementById('updated-info');
  info.classList.add('err');
  info.textContent = 'Error al actualizar';
  const btn = document.getElementById('btn-refresh');
  btn.classList.remove('loading');
  btn.disabled = false;
}

/* ============================================================
   CÁLCULOS Y RENDER
   ============================================================ */
function calcTotales() {
  let cesRep = registros.length, esperados = 0, presentes = 0, ausentes = 0;
  let elect = 0, internet = 0, cuidador = 0, coord = 0, desorden = 0;
  registros.forEach(function (r) {
    esperados += r.esperados;
    presentes += r.presentes;
    ausentes  += Math.max(0, r.esperados - r.presentes);
    elect += r.elect; internet += r.internet; cuidador += r.cuidador;
    coord += r.coord; desorden += r.desorden;
  });
  const totalInc = elect + internet + cuidador + coord + desorden;
  const pct = esperados > 0 ? Math.round((presentes / esperados) * 1000) / 10 : null;
  return { cesRep, esperados, presentes, ausentes, elect, internet, cuidador, coord, desorden, totalInc, pct };
}

function render() {
  const t = calcTotales();
  document.getElementById('header-sub').textContent =
    'Registro de incidencias y asistencia por Centro Educativo · ' + t.cesRep + ' CEs registrados';
  document.getElementById('ces-reportando').textContent = t.cesRep;
  document.getElementById('ces-reportando-sub').textContent = t.cesRep === 1 ? 'centro' : 'centros';
  document.getElementById('total-esperados').textContent = t.esperados;
  document.getElementById('total-presentes').textContent = t.presentes;
  document.getElementById('total-ausentes').textContent = t.ausentes;
  document.getElementById('pct-asistencia').textContent = t.pct !== null ? t.pct + '%' : '—';
  document.getElementById('total-incidencias').textContent = t.totalInc;
  document.getElementById('inc-elect').textContent = t.elect;
  document.getElementById('inc-internet').textContent = t.internet;
  document.getElementById('inc-cuidador').textContent = t.cuidador;
  document.getElementById('inc-coord').textContent = t.coord;
  document.getElementById('inc-desorden').textContent = t.desorden;
  actualizarTabla();
  actualizarGraficos(t);
}

function actualizarTabla() {
  const tbody = document.getElementById('tabla-body');
  tbody.innerHTML = '';
  if (registros.length === 0) {
    const tr = document.createElement('tr');
    tr.innerHTML = '<td colspan="11" class="center" style="padding:20px;color:var(--text3)">Sin datos disponibles.</td>';
    tbody.appendChild(tr);
    return;
  }
  registros.forEach(function (r) {
    const pct = r.esperados > 0 ? Math.round((r.presentes / r.esperados) * 100) : 0;
    const inc = r.elect + r.internet + r.cuidador + r.coord + r.desorden;
    const estado = inc === 0 ? '<span class="pill pill-ok">Sin incidencias</span>'
                 : inc <= 2 ? '<span class="pill pill-warn">' + inc + ' incid.</span>'
                 : '<span class="pill pill-err">' + inc + ' incid.</span>';
    const tr = document.createElement('tr');
    tr.innerHTML =
      '<td class="primary">' + r.codigo + '</td>' +
      '<td class="primary">' + r.nombre + '</td>' +
      '<td>' + r.monitor + '</td>' +
      '<td class="center">' + r.esperados + '</td>' +
      '<td class="center">' + r.presentes + '</td>' +
      '<td class="center">' + pct + '%</td>' +
      '<td class="center">' + inc + '</td>' +
      '<td>' + r.inicio + '</td>' +
      '<td>' + r.receso + '</td>' +
      '<td>' + r.fin + '</td>' +
      '<td class="center">' + estado + '</td>';
    tbody.appendChild(tr);
  });
}

function actualizarGraficos(t) {
  if (typeof Chart === 'undefined') return;

  if (chartInc) chartInc.destroy();
  chartInc = new Chart(document.getElementById('chartIncidencias'), {
    type: 'bar',
    data: {
      labels: ['Electricidad', 'Internet', 'Cuidador', 'Coordinador', 'Desorden'],
      datasets: [{
        label: 'Incidencias',
        data: [t.elect, t.internet, t.cuidador, t.coord, t.desorden],
        backgroundColor: ['#ba7517', '#185fa5', '#d85a30', '#a32d2d', '#534ab7'],
        borderRadius: 4
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      animation: false,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, ticks: { precision: 0, color: '#888780', font: { size: 10 } }, grid: { color: 'rgba(128,128,128,0.12)' } },
        x: { ticks: { color: '#888780', font: { size: 10 } }, grid: { display: false } }
      }
    }
  });

  const labels = registros.map(function (r) { return r.codigo; });
  const dataP = registros.map(function (r) { return r.presentes; });
  const dataA = registros.map(function (r) { return Math.max(0, r.esperados - r.presentes); });

  if (chartAsist) chartAsist.destroy();
  chartAsist = new Chart(document.getElementById('chartAsistencia'), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [
        { label: 'Presentes', data: dataP, backgroundColor: '#185fa5', borderRadius: 2 },
        { label: 'Ausentes',  data: dataA, backgroundColor: '#e2b27a', borderRadius: 2 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      animation: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { stacked: true, ticks: { color: '#888780', font: { size: 9 }, autoSkip: true, maxRotation: 70, minRotation: 45 }, grid: { display: false } },
        y: { stacked: true, beginAtZero: true, ticks: { color: '#888780', font: { size: 10 } }, grid: { color: 'rgba(128,128,128,0.12)' } }
      }
    }
  });
}

/* ============================================================
   ARRANQUE + AUTO-REFRESH CADA MINUTO
   ============================================================ */
fetchData();
setInterval(fetchData, REFRESH_MS);
