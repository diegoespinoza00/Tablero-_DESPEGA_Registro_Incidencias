<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tablero Operativo — Prueba DESPEGA</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #f5f4f0;
    --surface: #ffffff;
    --surface2: #f1efe8;
    --border: rgba(0,0,0,0.12);
    --border2: rgba(0,0,0,0.22);
    --text: #1a1a18;
    --text2: #5f5e5a;
    --text3: #888780;
    --radius: 12px;
    --radius-sm: 8px;
    --blue: #185fa5;
    --blue-bg: #e6f1fb;
    --blue-text: #0c447c;
    --green: #3b6d11;
    --green-bg: #eaf3de;
    --green-text: #27500a;
    --amber: #854f0b;
    --amber-bg: #faeeda;
    --amber-text: #633806;
    --red: #a32d2d;
    --red-bg: #fcebeb;
    --red-text: #791f1f;
    --coral: #993c1d;
    --coral-bg: #faece7;
    --coral-text: #712b13;
    --purple: #534ab7;
    --purple-bg: #eeedfe;
    --purple-text: #3c3489;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1c1c1a;
      --surface: #2c2c2a;
      --surface2: #242422;
      --border: rgba(255,255,255,0.12);
      --border2: rgba(255,255,255,0.22);
      --text: #f1efe8;
      --text2: #b4b2a9;
      --text3: #888780;
      --blue-bg: #0c447c;
      --blue-text: #b5d4f4;
      --green-bg: #27500a;
      --green-text: #c0dd97;
      --amber-bg: #633806;
      --amber-text: #fac775;
      --red-bg: #791f1f;
      --red-text: #f7c1c1;
      --coral-bg: #712b13;
      --coral-text: #f5c4b3;
      --purple-bg: #3c3489;
      --purple-text: #cecbf6;
    }
  }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    font-size: 14px;
    line-height: 1.5;
  }
  .page { max-width: 1100px; margin: 0 auto; padding: 24px 20px 48px; }

  /* HEADER */
  .header {
    display: flex; align-items: flex-start; justify-content: space-between;
    flex-wrap: wrap; gap: 12px;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 0.5px solid var(--border2);
  }
  .header-left h1 {
    font-size: 22px; font-weight: 500; color: var(--text); line-height: 1.3;
  }
  .header-left p { font-size: 13px; color: var(--text2); margin-top: 4px; }
  .header-right { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
  .badge-status {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 20px;
    font-size: 12px; font-weight: 500;
    background: var(--amber-bg); color: var(--amber-text);
  }
  .badge-status .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #ba7517; animation: pulse 1.8s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

  .refresh-controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; justify-content: flex-end; }
  .btn-refresh {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 14px; background: var(--blue-text); color: #fff;
    border: none; border-radius: var(--radius-sm); font-size: 12px;
    font-weight: 500; cursor: pointer; transition: opacity 0.15s;
  }
  .btn-refresh:hover { opacity: 0.88; }
  .btn-refresh:active { transform: scale(0.98); }
  .btn-refresh:disabled { opacity: 0.5; cursor: default; }
  .btn-refresh i { font-size: 15px; }
  .btn-refresh.loading i { animation: spin 0.9s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .updated-info { font-size: 11px; color: var(--text3); text-align: right; }
  .updated-info.err { color: var(--red); }

  /* SECTION LABEL */
  .section-label {
    font-size: 11px; font-weight: 500; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--text3);
    margin: 28px 0 12px;
  }

  /* METRIC CARDS */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 10px;
  }
  .metric-card {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px;
  }
  .metric-card .label {
    font-size: 11px; color: var(--text3); font-weight: 500;
    text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 6px;
    display: flex; align-items: center; gap: 5px;
  }
  .metric-card .value {
    font-size: 28px; font-weight: 500; color: var(--text); line-height: 1;
  }
  .metric-card .sub {
    font-size: 11px; color: var(--text3); margin-top: 4px;
  }
  .metric-card.blue { background: var(--blue-bg); border-color: transparent; }
  .metric-card.blue .label, .metric-card.blue .sub { color: var(--blue); }
  .metric-card.blue .value { color: var(--blue-text); }
  .metric-card.green { background: var(--green-bg); border-color: transparent; }
  .metric-card.green .label, .metric-card.green .sub { color: var(--green); }
  .metric-card.green .value { color: var(--green-text); }
  .metric-card.red { background: var(--red-bg); border-color: transparent; }
  .metric-card.red .label, .metric-card.red .sub { color: var(--red); }
  .metric-card.red .value { color: var(--red-text); }
  .metric-card.amber { background: var(--amber-bg); border-color: transparent; }
  .metric-card.amber .label, .metric-card.amber .sub { color: var(--amber); }
  .metric-card.amber .value { color: var(--amber-text); }
  .metric-card.purple { background: var(--purple-bg); border-color: transparent; }
  .metric-card.purple .label, .metric-card.purple .sub { color: var(--purple); }
  .metric-card.purple .value { color: var(--purple-text); }

  /* TWO-COL LAYOUT */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 640px) { .two-col { grid-template-columns: 1fr; } }

  /* CARD */
  .card {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 18px;
  }
  .card-title {
    font-size: 13px; font-weight: 500; color: var(--text);
    margin-bottom: 14px;
    display: flex; align-items: center; gap: 7px;
  }
  .card-title i { font-size: 16px; color: var(--text3); }

  /* TABLE */
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 12px; }
  thead tr { border-bottom: 0.5px solid var(--border2); }
  th {
    padding: 8px 10px; text-align: left;
    font-size: 10px; font-weight: 500; letter-spacing: 0.05em;
    text-transform: uppercase; color: var(--text3);
    white-space: nowrap;
  }
  td { padding: 9px 10px; border-bottom: 0.5px solid var(--border); color: var(--text2); }
  tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: var(--surface2); }
  td.primary { color: var(--text); font-weight: 500; }
  td.center { text-align: center; }

  .pill {
    display: inline-block; padding: 2px 8px;
    border-radius: 20px; font-size: 11px; font-weight: 500;
  }
  .pill-ok { background: var(--green-bg); color: var(--green-text); }
  .pill-warn { background: var(--amber-bg); color: var(--amber-text); }
  .pill-err { background: var(--red-bg); color: var(--red-text); }
  .pill-pending { background: var(--surface2); color: var(--text3); }

  /* INCIDENCIA ROW */
  .inc-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .inc-icon {
    width: 32px; height: 32px; border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; flex-shrink: 0;
  }
  .inc-icon.amber { background: var(--amber-bg); color: var(--amber); }
  .inc-icon.red { background: var(--red-bg); color: var(--red); }
  .inc-icon.blue { background: var(--blue-bg); color: var(--blue); }
  .inc-icon.coral { background: var(--coral-bg); color: var(--coral); }
  .inc-icon.purple { background: var(--purple-bg); color: var(--purple); }
  .inc-label { flex: 1; font-size: 12px; color: var(--text2); }
  .inc-count {
    font-size: 20px; font-weight: 500;
    color: var(--text); min-width: 32px; text-align: right;
  }

  /* FOOTER */
  .footer {
    margin-top: 36px; padding-top: 16px;
    border-top: 0.5px solid var(--border);
    font-size: 11px; color: var(--text3);
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
  }

  .banner {
    display: none; align-items: flex-start; gap: 8px;
    border-radius: var(--radius-sm); padding: 10px 12px;
    font-size: 12px; margin-bottom: 16px;
  }
  .banner i { font-size: 15px; flex-shrink: 0; margin-top: 1px; }
  .banner.err { background: var(--red-bg); color: var(--red-text); }
</style>
</head>
<body>
<div class="page">
  <h2 class="sr-only" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">
    Tablero operativo de la Prueba DESPEGA — registro de incidencias y asistencia por centro educativo
  </h2>

  <!-- HEADER -->
  <div class="header">
    <div class="header-left">
      <h1><i class="ti ti-school" style="font-size:20px;vertical-align:-3px;margin-right:6px;color:#185fa5" aria-hidden="true"></i>Prueba DESPEGA — Tablero operativo</h1>
      <p id="header-sub">Registro de incidencias y asistencia por Centro Educativo</p>
    </div>
    <div class="header-right">
      <span class="badge-status">
        <span class="dot"></span>
        En vivo
      </span>
      <div class="refresh-controls">
        <button class="btn-refresh" id="btn-refresh" onclick="fetchData()">
          <i class="ti ti-refresh" aria-hidden="true"></i> Actualizar
        </button>
      </div>
      <div class="updated-info" id="updated-info">Cargando datos…</div>
    </div>
  </div>

  <!-- ERROR BANNER -->
  <div class="banner err" id="error-banner" role="alert">
    <i class="ti ti-alert-triangle" aria-hidden="true"></i>
    <span id="error-text"></span>
  </div>

  <!-- MÉTRICAS ASISTENCIA -->
  <div class="section-label">Asistencia</div>
  <div class="metrics-grid" id="metricas-asistencia">
    <div class="metric-card blue">
      <div class="label"><i class="ti ti-building-school" aria-hidden="true"></i>CEs reportando</div>
      <div class="value" id="ces-reportando">0</div>
      <div class="sub" id="ces-reportando-sub">centros</div>
    </div>
    <div class="metric-card">
      <div class="label"><i class="ti ti-users" aria-hidden="true"></i>Alumnos esperados</div>
      <div class="value" id="total-esperados">0</div>
      <div class="sub">total convocados</div>
    </div>
    <div class="metric-card green">
      <div class="label"><i class="ti ti-user-check" aria-hidden="true"></i>Presentes</div>
      <div class="value" id="total-presentes">0</div>
      <div class="sub">alumnos</div>
    </div>
    <div class="metric-card amber">
      <div class="label"><i class="ti ti-user-off" aria-hidden="true"></i>Ausentes</div>
      <div class="value" id="total-ausentes">0</div>
      <div class="sub">alumnos</div>
    </div>
    <div class="metric-card purple">
      <div class="label"><i class="ti ti-percentage" aria-hidden="true"></i>% Asistencia</div>
      <div class="value" id="pct-asistencia">—</div>
      <div class="sub">global</div>
    </div>
    <div class="metric-card red">
      <div class="label"><i class="ti ti-alert-triangle" aria-hidden="true"></i>Total incidencias</div>
      <div class="value" id="total-incidencias">0</div>
      <div class="sub">registradas</div>
    </div>
  </div>

  <!-- DOS COLUMNAS: INCIDENCIAS + ASISTENCIA POR CE -->
  <div class="two-col" style="margin-top:16px">
    <!-- INCIDENCIAS DETALLE -->
    <div class="card">
      <div class="card-title"><i class="ti ti-alert-circle" aria-hidden="true"></i>Desglose de incidencias</div>

      <div class="inc-row">
        <div class="inc-icon amber"><i class="ti ti-bolt-off" aria-hidden="true"></i></div>
        <div class="inc-label">Falla eléctrica</div>
        <div class="inc-count" id="inc-elect">0</div>
      </div>
      <div class="inc-row">
        <div class="inc-icon blue"><i class="ti ti-wifi-off" aria-hidden="true"></i></div>
        <div class="inc-label">Sin internet</div>
        <div class="inc-count" id="inc-internet">0</div>
      </div>
      <div class="inc-row">
        <div class="inc-icon coral"><i class="ti ti-user-x" aria-hidden="true"></i></div>
        <div class="inc-label">Ausencia de cuidador</div>
        <div class="inc-count" id="inc-cuidador">0</div>
      </div>
      <div class="inc-row">
        <div class="inc-icon red"><i class="ti ti-id-badge-off" aria-hidden="true"></i></div>
        <div class="inc-label">Ausencia de coordinador</div>
        <div class="inc-count" id="inc-coord">0</div>
      </div>
      <div class="inc-row">
        <div class="inc-icon purple"><i class="ti ti-mood-confuzed" aria-hidden="true"></i></div>
        <div class="inc-label">Desorden exterior aula</div>
        <div class="inc-count" id="inc-desorden">0</div>
      </div>

      <div style="margin-top:16px; position:relative; height:160px;">
        <canvas id="chartIncidencias" role="img" aria-label="Gráfico de barras de incidencias por tipo"></canvas>
      </div>
    </div>

    <!-- ASISTENCIA POR CE (BARRAS) -->
    <div class="card">
      <div class="card-title"><i class="ti ti-chart-bar" aria-hidden="true"></i>Asistencia por centro educativo</div>
      <div style="position:relative; height:228px;">
        <canvas id="chartAsistencia" role="img" aria-label="Gráfico de asistencia por centro educativo"></canvas>
      </div>
      <div style="display:flex;gap:12px;margin-top:8px;font-size:11px;color:var(--text3);">
        <span style="display:flex;align-items:center;gap:4px;"><span style="width:10px;height:10px;border-radius:2px;background:#185fa5;"></span>Presentes</span>
        <span style="display:flex;align-items:center;gap:4px;"><span style="width:10px;height:10px;border-radius:2px;background:#e2b27a;"></span>Ausentes</span>
